#!/usr/bin/env bash
# agent-runner — 后台运行 Agent 任务，完成后写结果文件
# Usage: agent-runner <agent> <task_id> <task_text>
set -euo pipefail

AGENT="$1"
TASK_ID="$2"
TASK_TEXT="$3"
OUTFILE="/tmp/${TASK_ID}.out"
RESULT_FILE="${HOME}/.openclaw/mcp-bridge/workspace/tasks/${TASK_ID}.json"

mkdir -p "$(dirname "$RESULT_FILE")"

# 写入初始状态
echo "{\"task_id\":\"$TASK_ID\",\"agent\":\"$AGENT\",\"status\":\"running\"}" > "$RESULT_FILE"

# 执行任务
case "$AGENT" in
  hermes)
    hermes -z "$TASK_TEXT" --yolo > "$OUTFILE" 2>&1
    ;;
  qodercli)
    qodercli -p "$TASK_TEXT" --dangerously-skip-permissions > "$OUTFILE" 2>&1
    ;;
  openclaw)
    openclaw session start --prompt "$TASK_TEXT" > "$OUTFILE" 2>&1
    ;;
esac

EXIT_CODE=$?

# 写结果
python3 -c "
import json
with open('$OUTFILE') as f:
    output = f.read()[:5000]
json.dump({'task_id':'$TASK_ID','agent':'$AGENT','status':'completed','output':output,'exit_code':$EXIT_CODE}, open('$RESULT_FILE','w'))
"
